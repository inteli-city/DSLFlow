# ── Runtime data directory ────────────────────────────────────────────────────
# All Node-RED state (flows, projects, config, packages) lives in dslflow_data/.
# It is bind-mounted into the container and visible on the host, but it is
# not source-controlled — Node-RED Projects manages versioning of flows internally.
dslflow_data/

# ── Node-RED runtime files (generated at startup — must never be committed) ───
# These are written by Node-RED into its userDir. When running via Docker, the
# userDir is /data (→ ./dslflow_data). If Node-RED is ever run locally with the
# repo root as userDir, these would appear here and must not be committed.
.config.*.json
.config.*.json.backup

# ── Node-RED runtime directories ──────────────────────────────────────────────
# Also generated by Node-RED when userDir points at the repo root.
projects/
lib/
context/

# ── Node.js dependencies ──────────────────────────────────────────────────────
node_modules/

# ── Python virtual environment ────────────────────────────────────────────────
venv/

# ── Credentials & secrets ─────────────────────────────────────────────────────
*_cred.json
.env

# ── Backup files ──────────────────────────────────────────────────────────────
*.backup

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── External tool auth state ──────────────────────────────────────────────────
.wwebjs_auth/
.wwebjs_cache/

# ── Runtime data directory (hidden) ───────────────────────────────────────────
.runtime_data/

rawdata/
