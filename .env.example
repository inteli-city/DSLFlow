# DSLFlow — required environment variables
#
# Copy this file to .env before starting the container:
#
#   cp .env.example .env
#
# The container will not start if NODE_RED_ADMIN_USER or
# NODE_RED_ADMIN_PASSWORD_HASH are missing or empty.
#
# To generate a new bcrypt hash for a different password:
#   npx node-red-admin hash-pw

# Username for the Node-RED editor and admin API.
NODE_RED_ADMIN_USER=admin

# Bcrypt hash of the admin password.
# The hash below corresponds to password: dslflow
# It is provided as a bootstrap default for local development only.
# Replace it for any environment where access control actually matters.
# Single quotes prevent Docker Compose from interpolating the $ signs in the hash.
NODE_RED_ADMIN_PASSWORD_HASH='$2y$08$SvndJSicHrJN8u.WRqE9b.FvIXB1QiaD717cnNCjpiVseOcGoNJIO'
